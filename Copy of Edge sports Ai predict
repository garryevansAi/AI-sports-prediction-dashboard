      \"spread_away_odds\": -110\n","            }\n","        ]\n","    }\n","}'''\n","\n","nba_game_details_data = json.loads(captured_output_str)\n","\n","# 2. Utility Logic\n","def convert_american_odds_to_implied_probability(american_odds):\n","    if american_odds > 0:\n","        return 100 / (american_odds + 100)\n","    return abs(american_odds) / (abs(american_odds) + 100)\n","\n","class TeamFormPlugin:\n","    def __init__(self):\n","        self.team_forms = {\n","            \"Sixers\": [1, 1, 0, 1, 1], \"Pistons\": [0, 0, 1, 0, 0],\n","            \"Suns\": [1, 1, 1, 1, 0], \"Pacers\": [0, 0, 0, 0, 1],\n","            \"Wizards\": [0, 0, 0, 0, 0], \"Magic\": [1, 1, 1, 1, 1],\n","            \"Nets\": [0, 1, 0, 1, 0], \"Hawks\": [1, 0, 1, 0, 1]\n","        }\n","    def get_score(self, team): return sum(self.team_forms.get(team, [0]*5))\n","\n","def predict_nba_game(game_data):\n","    odds = game_data['odds']\n","    avg_h = sum(e['form_adjusted_true_prob_home'] for e in odds) / len(odds)\n","    avg_a = sum(e['form_adjusted_true_prob_away'] for e in odds) / len(odds)\n","    winner = odds[0]['home_team'] if avg_h > avg_a else odds[0]['away_team']\n","    prob = max(avg_h, avg_a)\n","    return {\"predicted_winner\": winner, \"predicted_win_probability\": round(prob, 4)}\n","\n","# 3. Processing Pipeline\n","form_plugin = TeamFormPlugin()\n","for game_key, data in nba_game_details_data.items():\n","    for entry in data['odds']:\n","        # Probabilities & Vig\n","        ip_h = convert_american_odds_to_implied_probability(entry['money_line_home'])\n","        ip_a = convert_american_odds_to_implied_probability(entry['money_line_away'])\n","        sum_ip = ip_h + ip_a\n","        entry['true_prob_home'] = ip_h / sum_ip\n","        entry['true_prob_away'] = ip_a / sum_ip\n","\n","        # Form Adjustments\n","        fs_h, fs_a = form_plugin.get_score(entry['home_team']), form_plugin.get_score(entry['away_team'])\n","        adj = 0.02 if fs_h > fs_a else (-0.02 if fs_a > fs_h else 0)\n","        entry['form_adjusted_true_prob_home'] = round(entry['true_prob_home'] + adj, 4)\n","        entry['form_adjusted_true_prob_away'] = round(entry['true_prob_away'] - adj, 4)\n","\n","    # Generate and store predictions\n","    data['predictions'] = predict_nba_game(data)\n","\n","print(\"NBA Prediction Engine execution successful. Predictions generated for all games.\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["NBA Prediction Engine execution successful. Predictions generated for all games.\n"]}]},{"cell_type":"markdown","metadata":{"id":"2ea2adf6"},"source":["## Rank Picks by Confidence\n","\n","### Subtask:\n","Parse the prediction results to identify and sort the money line picks by win probability, specifically highlighting and ranking the requested teams.\n"]},{"cell_type":"markdown","metadata":{"id":"de939da8"},"source":["**Reasoning**:\n","I will consolidate the prediction extraction logic into a Python code block to rank the games by win probability, ensuring all relevant teams like the Pistons are highlighted as requested.\n","\n"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ae5f3f51","executionInfo":{"status":"ok","timestamp":1773438359851,"user_tz":240,"elapsed":23,"user":{"displayName":"garry evans","userId":"18049878967172356456"}},"outputId":"33da7d49-9ba0-4547-9c5a-fa1b185567f9"},"source":["import json\n","\n","# Assuming nba_game_details_data is already populated in the kernel state\n","ranked_picks = []\n","\n","for game_key, game_info in nba_game_details_data.items():\n","    predictions = game_info.get('predictions', {})\n","    if not predictions:\n","        continue\n","\n","    # Extract basic info from the first odds entry\n","    representative = game_info['odds'][0]\n","    pick_entry = {\n","        'game': game_key,\n","        'home_team': representative['home_team'],\n","        'away_team': representative