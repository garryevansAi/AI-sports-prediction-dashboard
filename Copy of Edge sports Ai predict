ebounds\", \"over_under\": 7.5, \"over_odds\": -110, \"under_odds\": -110, \"source\": \"Hard Rock Bet\"\n","                    },\n","                    {\n","                        \"game_id\": \"nba_wizards_magic\", \"player\": \"Desmond Bane\", \"team\": \"Magic\", # New Player Prop\n","                        \"prop_type\": \"Points\", \"over_under\": 18.5, \"over_odds\": -110, \"under_odds\": -110, \"source\": \"Hard Rock Bet\"\n","                    }\n","                ]\n","            },\n","            \"Nets_Hawks\": {\n","                \"odds\": [\n","                    {\n","                        \"game_id\": \"nba_nets_hawks\", \"home_team\": \"Hawks\", \"away_team\": \"Nets\",\n","                        \"source\": \"CBS Sports\", \"money_line_home\": -160, \"money_line_away\": 130,\n","                        \"spread_home\": -3.5, \"spread_home_odds\": -110, \"spread_away\": 3.5, \"spread_away_odds\": -110\n","                    }\n","                ],\n","                \"player_props\": [\n","                    {\n","                        \"game_id\": \"nba_nets_hawks\", \"player\": \"Trae Young\", \"team\": \"Wizards\", # Changed team\n","                        \"prop_type\": \"Assists\", \"over_under\": 9.5, \"over_odds\": -110, \"under_odds\": -110, \"source\": \"CBS Sports\"\n","                    },\n","                    {\n","                        \"game_id\": \"nba_nets_hawks\", \"player\": \"Mikal Bridges\", \"team\": \"Nets\",\n","                        \"prop_type\": \"Points\", \"over_under\": 20.5, \"over_odds\": -110, \"under_odds\": -110, \"source\": \"CBS Sports\"\n","                    }\n","                ]\n","            }\n","        }\n","\n","    def get_nba_game_details(self, home_team: str, away_team: str, game_date: date) -> dict:\n","        game_key_forward = f\"{away_team.replace(' ', '_')}_{home_team.replace(' ', '_')}\"\n","        reversed_game_key = f\"{home_team.replace(' ', '_')}_{away_team.replace(' ', '_')}\"\n","\n","        # For mock data, we'll return the pre-defined data, ignoring game_date for now.\n","        if game_key_forward in self.nba_mock_data:\n","            # Return a dictionary containing both requested_game string and the odds/player_props dict\n","            return {\"requested_game\": f\"{away_team} @ {home_team}\", **self.nba_mock_data[game_key_forward]}\n","        elif reversed_game_key in self.nba_mock_data:\n","            return {\"requested_game\": f\"{away_team} @ {home_team}\", **self.nba_mock_data[reversed_game_key]}\n","        else:\n","            return {\"requested_game\": f\"{away_team} @ {home_team}\", \"message\": \"No mock data available for this specific game.\", \"odds\": [], \"player_props\": []}\n","\n","    def get_all_odds(self):\n","        return {\n","            \"MLB\": [\n","                {\n","                    \"game_id\": \"mlb_1\", \"home_team\": \"Yankees\", \"away_team\": \"Red Sox\",\n","                    \"source\": \"Hard Rock Bet\", \"money_line_home\": -150, \"money_line_away\": 130\n","                },\n","                {\n","                    \"game_id\": \"mlb_1\", \"home_team\": \"Yankees\", \"away_team\": \"Red Sox\",\n","                    \"source\": \"CBS Sports\", \"money_line_home\": -145, \"money_line_away\": 125\n","                }\n","            ],\n","            \"NBA\": [\n","                {\n","                    \"game_id\": \"nba_1\", \"home_team\": \"Warriors\", \"away_team\": \"Lakers\",\n","                    \"source\": \"Hard Rock Bet\", \"money_line_home\": -120, \"money_line_away\": 100\n","                },\n","                {\n","                    \"game_id\": \"nba_1\", \"home_team\": \"Warriors\", \"away_team\": \"Lakers\",\n","                    \"source\": \"CBS Sports\", \"money_line_home\": -125, \"money_line_away\": 105\n","                }\n","            ],\n","            \"NFL\": [\n","                {\n","           