elf, team_name):\n","        return self.team_forms.get(team_name, {\"team\": team_name, \"form\": [0, 0, 0, 0, 0]}) # Default to no wins\n","\n","# --- Prediction Algorithm for Money Line and Spread ---\n","def predict_nba_game(game_data: dict) -> dict:\n","    if not game_data or not game_data.get('odds'):\n","        return {\"error\": \"No odds data available for this game.\"}\n","\n","    valid_odds = [e for e in game_data['odds'] if e.get('form_adjusted_true_prob_home') is not None and e.get('form_adjusted_true_prob_away') is not None]\n","\n","    if not valid_odds:\n","        return {\"error\": \"No valid money line odds to make a prediction.\"}\n","\n","    representative_odds = valid_odds[0]\n","    home_team = representative_odds['home_team']\n","    away_team = representative_odds['away_team']\n","    game_id = representative_odds['game_id']\n","\n","    avg_form_adjusted_true_prob_home = sum(e['form_adjusted_true_prob_home'] for e in valid_odds) / len(valid_odds)\n","    avg_form_adjusted_true_prob_away = sum(e['form_adjusted_true_prob_away'] for e in valid_odds) / len(valid_odds)\n","\n","    predicted_winner = None\n","    predicted_win_probability = 0.0\n","\n","    if avg_form_adjusted_true_prob_home > avg_form_adjusted_true_prob_away:\n","        predicted_winner = home_team\n","        predicted_win_probability = avg_form_adjusted_true_prob_home\n","    else:\n","        predicted_winner = away_team\n","        predicted_win_probability = avg_form_adjusted_true_prob_away\n","\n","    predicted_spread_outcome = \"No clear spread prediction\"\n","    predicted_spread_confidence = 0.0\n","\n","    first_spread_home = representative_odds.get('spread_home')\n","    first_spread_away = representative_odds.get('spread_away')\n","\n","    if first_spread_home is not None and first_spread_away is not None:\n","        bookie_favored_team = None\n","        if first_spread_home < 0:\n","            bookie_favored_team = home_team\n","            spread_value = abs(first_spread_home)\n","        elif first_spread_away < 0:\n","            bookie_favored_team = away_team\n","            spread_value = abs(first_spread_away)\n","        else:\n","            bookie_favored_team = None\n","            spread_value = 0.0\n","\n","        if bookie_favored_team:\n","            if predicted_winner == bookie_favored_team:\n","                if (predicted_winner == home_team and avg_form_adjusted_true_prob_home > 0.60 and abs(first_spread_home) < 7.0) or \\\n","                   (predicted_winner == away_team and avg_form_adjusted_true_prob_away > 0.60 and abs(first_spread_away) < 7.0):\n","                    spread_val_for_outcome = abs(first_spread_home) if predicted_winner == home_team else abs(first_spread_away)\n","                    predicted_spread_outcome = f\"{predicted_winner} to cover -{spread_val_for_outcome}\"\n","                    predicted_spread_confidence = min(1.0, predicted_win_probability + 0.1)\n","                else:\n","                    underdog_for_spread = away_team if predicted_winner == home_team else home_team\n","                    spread_val_for_outcome = abs(first_spread_home) if predicted_winner == home_team else abs(first_spread_away) # Use original spread values\n","                    predicted_spread_outcome = f\"{underdog_for_spread} to cover +{spread_val_for_outcome}\"\n","                    predicted_spread_confidence = max(0.1, predicted_win_probability - 0.1)\n","            else: # Predicted winner is different from bookie favored\n","                spread_val_for_outcome = abs(first_spread_home) if predicted_winner == home_team else abs(first_spread_away)\n","                predicted_spread_outcome = f\"{predicted_winner} to cover +{spread_val_for_outcome}\"\n","                predicted_spread_confidence = max(0.1, predicted_win_probability - 0.05)\n","        else:\n","            predicted_spread_outcome = \"No clear spread favorite (market)\"\n","            predicted_spread_confidence = 0.0\n","\n","    return {\n","        \"game_id\": game_id,\n","        \"predicted_winner\": predicted_winner,\n","        \"predicted_win_probability\": round(predicted_win_probability, 4),\n","        \"predicted_spread_outcome\": predicted_spread_outcome,\n","        \"predicted_spread_confidence\": round(predicted_spread_confidence, 4)\n","    }\n","\n","# --- New function: Predict Player Prop ---\n","def predict_player_prop(prop_data: dict) -> dict:\n","    if not prop_data:\n","        return {\"error\": \"No player prop data available.\"}\n","\n","    over_odds = prop_data.get('over_odds')\n","    under_odds = prop_data.get('under_odds')\n","\n","    if over_odds is None or under_odds is None:\n","        return {\"error\": \"Missing over_odds or under_odds for player prop.\"}\n","\n","    implied_prob_over = convert_american_odds_to_implied_probability(over_odds)\n","    implied_prob_under = convert_american_odds_to_implied_probability(under_odds)\n","\n","    vig_prop = (implied_prob_over + implied_prob_under) - 1\n","    if (implied_prob_over + implied_prob_under) > 0:\n","        true_prob_over = implied_prob_over / (implied_prob_over + implied_prob_under)\n","        true_prob_under = implied_prob_under / (implied_prob_over + implied_prob_under)\n","    else:\n","        true_prob_over = 0.5\n","        true_prob_under = 0.5\n","\n","    predicted_outcome = \"\"\n","    predicted_confidence = 0.0\n","    if true_prob_over > true_prob_under:\n","        predicted_outcome = f\"Over {prop_data['over_under']}\"\n","        predicted_confidence = true_prob_over\n","    else:\n","        predicted_outcome = f\"Under {prop_data['over_under']}\"\n","        predicted_confidence = true_prob_under\n","\n","    return {\n","        \"predicted_prop_outcome\": predicted_outcome,\n","        \"predicted_prop_confidence\": round(predicted_confidence, 4),\n","        \"true_prob_over\": round(true_prob_over, 4),\n","        \"true_prob_under\": round(true_prob_under, 4),\n","        \"vig_prop\": round(vig_prop, 4)\n","    }\n","\n","# --- New function: build_parlay ---\n","def build_parlay(predictions_list: list) -> dict:\n","    \"\"\"\n","    Calculates combined odds and overall confidence for a parlay bet.\n","    \"\"\"\n","    if not predictions_list:\n","        return {\"error\": \"No predictions provided for parlay.\", \"parlay_legs\": [], \"combined_american_odds\": 0, \"overall_confidence\": 0.0}\n","\n","    combined_decimal_odds = 1.0\n","    overall_confidence = 1.0\n","    parlay_legs_details = []\n","\n","    def american_to_decimal(american_odds):\n","        if american_odds >= 0:\n","            return american_odds / 100 + 1\n","        else:\n","            return 100 / abs(american_odds) + 1\n","\n","    for pred in predictions_list:\n","        predicted_outcome = pred.get('predicted_outcome')\n","        predicted_confidence = pred.get('predicted_confidence')\n","        current_american_odds = pred.get('odds')\n","\n","        # Check for player prop odds specifically\n","        if pred.get('predicted_prop_outcome'): # It's a player prop\n","            predicted_outcome = pred['predicted_prop_outcome']\n","            predicted_confidence = pred['predicted_prop_confidence']\n","            if predicted_outcome.startswith('Over'):\n","                current_american_odds = pred['over_odds']\n","            elif predicted_outcome.startswith('Under'):\n","                current_american_odds = pred['under_odds']\n","\n","        if predicted_outcome is None or predicted_confidence is None or current_american_odds is None:\n","            # print(f\"Warning: Missing required fields (outcome, confidence, odds) in a parlay leg: {pred})\") # Removed for cleaner output\n","            continue # Skip this leg if incomplete\n","\n","        current_decimal_odds = american_to_decimal(current_american_odds)\n","        combined_decimal_odds *= current_decimal_odds\n","        overall_confidence *= predicted_confidence\n","        parlay_legs_details.append(pred) # Append the full prediction dictionary\n","\n","    if not parlay_legs_details: # If all legs were skipped\n","        return {\"error\": \"Could not form parlay due to incomplete legs.\", \"parlay_legs\": [], \"combined_american_odds\": 0, \"overall_confidence\": 0.0}\n","\n","    # Convert combined decimal odds back to American odds\n","    if combined_decimal_odds == 1.0:\n","        combined_american_odds = 0 # Represents even money or a push\n","    elif combined_decimal_odds > 1.0:\n","        if combined_decimal_odds >= 2.0:\n","            combined_american_odds = round((combined_decimal_odds - 1) * 100)\n","        else:\n","            # Handle decimal odds between 1.0 and 2.0 (which correspond to negative American odds)\n","            # Ensure (combined_decimal_odds - 1) is not zero to avoid ZeroDivisionError\n","            if (combined_decimal_odds - 1) > 0:\n","                combined_american_odds = round(-100 / (combined_decimal_odds - 1))\n","            else:\n","                combined_american_odds = 0 # Or handle as an error/edge case\n","    else:\n","        combined_american_odds = \"N/A\" # Should not happen with valid odds\n","\n","\n","    return {\n","        \"parlay_legs\": parlay_legs_details,\n","        \"combined_american_odds\": combined_american_odds,\n","        \"overall_confidence\": round(overall_confidence, 4)\n","    }\n","\n","\n","# --- load_sports_data function (INTEGRATED) ---\n","def load_sports_data():\n","    scraper = AuthenticOddsScraper()\n","    # For this demonstration, we'll return all available mock odds from the scraper\n","    all_odds = scraper.get_all_odds()\n","    return all_odds\n","\n","\n","# --- Main function to orchestrate and print output ---\n","def main():\n","    # Load all sports data using the integrated load_sports_data function\n","    sports_data = load_sports_data()\n","\n","    # Print the comprehensive sports_data dictionary to standard output\n","    print(json.dumps(sports_data, indent=4))\n","\n","if __name__ == \"__main__\":\n","    main()"],"execution_count":null,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"9948c9c0"},"source":["I've modified `app.py` to include the `load_sports_data` function, which now uses the `AuthenticOddsScraper` to retrieve all mock odds. The `main` function calls `load_sports_data` and prints its output."]},{"cell_type":"code","metadata":{"id":"b4b7ec5e"},"source":["import subprocess\n","import os\n","import json\n","\n","file_path = '/content/app.py'\n","\n","if os.path.exists(file_path):\n","    print(\"Running app.py to capture all sports odds from load_sports_data...\")\n","    try:\n","        result = subprocess.run(['python', file_path], capture_output=True, text=True, check=True)\n","        captured_output_str = result.stdout\n","        print(\"--- Captured Output from app.py ---\")\n","        print(captured_output_str)\n","        print(\"--- End of Captured Output ---\")\n","\n","        # Parse the captured JSON string into a Python dictionary\n","        all_sports_odds = json.loads(captured_output_str)\n","        print(f\"Successfully parsed all sports odds for {len(all_sports_odds)} sports categories.\")\n","\n","    except subprocess.CalledProcessError as e:\n","        print(f\"Error running app.py: {e}\")\n","        print(f\"Stderr: {e.stderr}\")\n","    except json.JSONDecodeError as e:\n","        print(f\"Error decoding JSON from app.py output: {e}\")\n","        print(f\"Output: {captured_output_str}\")\n","else:\n","    print(f\"Error: The file '{file_path}' was not found. Please ensure app.py is available.\")"],"execution_count":null,"outputs":[]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":211},"id":"2e46bcad","executionInfo":{"status":"error","timestamp":1778892172305,"user_tz":240,"elapsed":213,"user":{"displayName":"garry evans","userId":"1804987896717235