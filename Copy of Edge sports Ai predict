\": {\"team\": \"Dodgers\", \"form\": [1, 1, 1, 0, 1]}, # W W W L W\n","            \"Giants\": {\"team\": \"Giants\", \"form\": [0, 0, 1, 1, 0]}, # L L W W L\n","            \"Chiefs\": {\"team\": \"Chiefs\", \"form\": [1, 1, 1, 1, 1]}, # W W W W W\n","            \"Bills\": {\"team\": \"Bills\", \"form\": [0, 0, 0, 1, 0]},   # L L L W L\n","            \"Warriors\": {\"team\": \"Warriors\", \"form\": [1, 1, 0, 1, 0]}, # W W L W L\n","            \"Lakers\": {\"team\": \"Lakers\", \"form\": [0, 0, 1, 0, 1]}, # L L W L W\n","            \"Bruins\": {\"team\": \"Bruins\", \"form\": [1, 1, 1, 0, 1]}, # NHL\n","            \"Maple Leafs\": {\"team\": \"Maple Leafs\", \"form\": [0, 1, 0, 0, 0]},\n","            \"Duke\": {\"team\": \"Duke\", \"form\": [1, 1, 1, 1, 1]}, # NCAAB\n","            \"UNC\": {\"team\": \"UNC\", \"form\": [0, 0, 1, 0, 1]},\n","        }\n","\n","    def get_form_data(self, team_name):\n","        # Return specific form data or a default if not found\n","        return self.team_forms.get(team_name, {\"team\": team_name, \"form\": [0, 0, 0, 0, 0]})\n","\n","# Placeholder for build_sports_engine function (kept for context)\n","def build_sports_engine(plugins=None):\n","    if plugins is None:\n","        plugins = []\n","\n","    team_form_plugin = None\n","    for plugin in plugins:\n","        if isinstance(plugin, TeamFormPlugin):\n","            team_form_plugin = plugin\n","            break\n","\n","    # Simulate prediction data generation for MLB\n","    mlb_predictions = [\n","        {\"game_id\": \"mlb_1\", \"sport\": \"MLB\", \"home_team\": \"Yankees\", \"away_team\": \"Red Sox\", \"prediction_type\": \"Money Line\", \"value\": \"Yankees\", \"confidence\": 0.65, \"odds\": -150},\n","        {\"game_id\": \"mlb_1\", \"sport\": \"MLB\", \"home_team\": \"Yankees\", \"away_team\": \"Red Sox\", \"prediction_type\": \"Player Prop\", \"prop\": \"Total Bases\", \"player\": \"Aaron Judge\", \"over_under\": 1.5, \"confidence\": 0.75},\n","        {\"game_id\": \"mlb_2\", \"sport\": \"MLB\", \"home_team\": \"Dodgers\", \"away_team\": \"Giants\", \"prediction_type\": \"Money Line\", \"value\": \"Dodgers\", \"confidence\": 0.70, \"odds\": -180},\n","        {\"game_id\": \"mlb_2\", \"sport\": \"MLB\", \"home_team\": \"Dodgers\", \"away_team\": \"Giants\", \"prediction_type\": \"Player Prop\", \"prop\": \"Strikeouts\", \"player\": \"Clayton Kershaw\", \"over_under\": 6.5, \"confidence\": 0.82}\n","    ]\n","\n","    # Simulate prediction data generation for NBA\n","    nba_predictions = [\n","        {\"game_id\": \"nba_1\", \"sport\": \"NBA\", \"home_team\": \"Warriors\", \"away_team\": \"Lakers\", \"prediction_type\": \"Team Win\", \"value\": \"Warriors\", \"confidence\": 0.60, \"odds\": -120},\n","        {\"game_id\": \"nba_1\", \"sport\": \"NBA\", \"home_team\": \"Warriors\", \"away_team\": \"Lakers\", \"prediction_type\": \"Player Prop\", \"prop\": \"Points\", \"player\": \"LeBron James\", \"over_under\": 28.5, \"confidence\": 0.72},\n","        {\"game_id\": \"nba_1\", \"sport\": \"NBA\", \"home_team\": \"Warriors\", \"away_team\": \"Lakers\", \"prediction_type\": \"Player Prop\", \"prop\": \"Rebounds\", \"player\": \"Anthony Davis\", \"over_under\": 10.5, \"confidence\": 0.68},\n","    ]\n","\n","    # Simulate prediction data generation for NHL\n","    nhl_predictions = [\n","        {\"game_id\": \"nhl_1\", \"sport\": \"NHL\", \"home_team\": \"Bruins\", \"away_team\": \"Maple Leafs\", \"prediction_type\": \"Money Line\", \"value\": \"Bruins\", \"confidence\": 0.58, \"odds\": -130},\n","        {\"game_id\": \"nhl_1\", \"sport\": \"NHL\", \"home_team\": \"Bruins\", \"away_team\": \"Maple Leafs\", \"prediction_type\": \"Player Prop\", \"prop\": \"Goals\", \"player\": \"Auston Matthews\", \"over_under\": 0.5, \"confidence\": 0.65},\n","    ]\n","\n","    # Simulate prediction data generation for NCAA Men's Basketball (NCAAB)\n","    ncaab_predictions = [\n","        {\"game_id\": \"ncaab_1\", \"sport\": \"NCAAB\", \"home_team\": \"Duke\", \"away_team\": \"UNC\", \"prediction_type\": \"Team Win\", \"value\": \"Duke\", \"confidence\": 0.78, \"odds\": -200},\n","        {\"game_id\": \"ncaab_1\", \"sport\": \"NCAAB\", \"home_team\": \"Duke\", \"away_team\": \"UNC\", \"prediction_type\": \"Player Prop\", \"prop\": \"Points\", \"player\": \"Kyle Filipowski\", \"over_under\": 18.5, \"confidence\": 0.70},\n","    ]\n","\n","\n","    all_predictions = {\n","        \"mlb\": mlb_predictions,\n","        \"nba\": nba_predictions,\n","        \"nhl\": nhl_predictions,\n","        \"ncaab\": ncaab_predictions,\n","    }\n","\n","    # Apply TeamFormPlugin logic if available\n","    if team_form_plugin:\n","        for sport in all_predictions:\n","            for prediction in all_predictions[sport]:\n","                if prediction.get('prediction_type') in [\"Money Line\", \"Team Win\", \"Player Prop\"]:\n","                    home_team = prediction['home_team']\n","                    away_team = prediction['away_team']\n","\n","                    home_form_data = team_form_plugin.get_form_data(home_team)\n","                    away_form_data = team_form_plugin.get_form_data(away_team)\n","\n","                    home_form_score = sum(home_form_data['form'])\n","                    away_form_score = sum(away_form_data['form'])\n","\n","                    confidence_adjustment = 0\n","                    notes = \"\"\n","                    if home_form_score > away_form_score:\n","                        confidence_adjustment = 0.05\n","                        notes = f\"Confidence increased by {confidence_adjustment*100:.0f}% due to better home team form ({home_team}).\"\n","                    elif away_form_score > home_form_score:\n","                        confidence_adjustment = -0.05\n","                        notes = f\"Confidence decreased by {abs(confidence_adjustment)*100:.0f}% due to better away team form ({away_team}).\"\n","                    else:\