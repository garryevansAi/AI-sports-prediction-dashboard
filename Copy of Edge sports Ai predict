\"\"\n","    Converts American odds to implied win probability.\n","    Handles both positive (underdog) and negative (favorite) odds.\n","    \"\"\"\n","    if american_odds > 0:\n","        return 100 / (american_odds + 100)\n","    elif american_odds < 0:\n","        return abs(american_odds) / (abs(american_odds) + 100)\n","    else:\n","        return 0.5 # For even odds (0 is usually not used, but handling for completeness)\n","\n","class TeamFormPlugin:\n","    def __init__(self):\n","        self.team_forms = {\n","            \"Sixers\": {\"team\": \"Sixers\", \"form\": [1, 1, 0, 1, 1]}, # W W L W W\n","            \"Pistons\": {\"team\": \"Pistons\", \"form\": [0, 0, 1, 0, 0]}, # L L W L L\n","            \"Suns\": {\"team\": \"Suns\", \"form\": [1, 1, 1, 1, 0]}, # W W W W L\n","            \"Pacers\": {\"team\": \"Pacers\", \"form\": [0, 0, 0, 0, 1]}, # L L L L W\n","            \"Wizards\": {\"team\": \"Wizards\", \"form\": [0, 0, 0, 0, 0]}, # L L L L L\n","            \"Magic\": {\"team\": \"Magic\", \"form\": [1, 1, 1, 1, 1]}, # W W W W W\n","            \"Nets\": {\"team\": \"Nets\", \"form\": [0, 1, 0, 1, 0]}, # L W L W L\n","            \"Hawks\": {\"team\": \"Hawks\", \"form\": [1, 0, 1, 0, 1]} # W L W L W\n","        }\n","\n","    def get_form_data(self, team_name):\n","        return self.team_forms.get(team_name, {\"team\": team_name, \"form\": [0, 0, 0, 0, 0]}) # Default to no wins\n","\n","def predict_nba_game(game_data: dict) -> dict:\n","    \"\"\"\n","    Generates rule-based predictions for NBA games based on aggregated odds and form-adjusted probabilities.\n","    \"\"\"\n","    if not game_data or not game_data.get('odds'):\n","        return {\"error\": \"No odds data available for this game.\"}\n","\n","    representative_odds = game_data['odds'][0]\n","    home_team = representative_odds['home_team']\n","    away_team = representative_odds['away_team']\n","    game_id = representative_odds['game_id']\n","\n","    avg_form_adjusted_true_prob_home = sum(e['form_adjusted_true_prob_home'] for e in game_data['odds']) / len(game_data['odds'])\n","    avg_form_adjusted_true_prob_away = sum(e['form_adjusted_true_prob_away'] for e in game_data['odds']) / len(game_data['odds'])\n","\n","    predicted_winner = None\n","    predicted_win_probability = 0.0\n","\n","    if avg_form_adjusted_true_prob_home > avg_form_adjusted_true_prob_away:\n","        predicted_winner = home_team\n","        predicted_win_probability = avg_form_adjusted_true_prob_home\n","    else:\n","        predicted_winner = away_team\n","        predicted_win_probability = avg_form_adjusted_true_prob_away\n","\n","    predicted_spread_outcome = \"No clear spread prediction\"\n","    predicted_spread_confidence = 0.0\n","\n","    first_spread_home = representative_odds.get('spread_home')\n","    first_spread_away = representative_odds.get('spread_away')\n","\n","    if first_spread_home is not None and first_spread_away is not None:\n","        bookie_favored_team = None\n","        if first_spread_home < 0:\n","            bookie_favored_team = home_team\n","        elif first_spread_away < 0:\n","            bookie_favored_team = away_team\n","\n","        if predicted_winner == bookie_favored_team:\n","            if predicted_winner == home_team and avg_form_adjusted_true_prob_home > 0.60 and abs(first_spread_home) < 7.0:\n","                predicted_spread_outcome = f\"{home_team} to cover {-abs(first_spread_home)}\"\n","                predicted_spread_confidence = min(1.0, predicted_win_probability + 0.1)\n","            elif predicted_winner == away_team and avg_form_adjusted_true_prob_away > 0.60 and abs(first_spread_away) < 7.0:\n","                predicted_spread_outcome = f\"{away_team} to cover {-abs(first_spread_away)}\"\n","                predicted_spread_confidence = min(1.0, predicted_win_probability + 0.1)\n","            else:\n","                predicted_spread_outcome = f\"{(away_team if predicted_winner == home_team else home_team)} to cover {abs(first_spread_away if predicted_winner == home_team else first_spread_home)}\"\n","                predicted_spread_confidence = max(0.1, predicted_win_probability - 0.1)\n","        else:\n","            if predicted_winner == home_team:\n","                predicted_spread_outcome = f\"{home_team} to cover {abs(first_spread_home)}\"\n","                predicted_spread_confidence = max(0.1, predicted_win_probability - 0.05)\n","            elif predicted_winner == away_team:\n","                predicted_spread_outcome = f\"{away_team} to cover {abs(first_spread_away)}\"\n","                predicted_spread_confidence = max(0.1, predicted_win_probability - 0.05)\n","\n","    return {\n","        \"game_id\": game_id,\n","        \"predicted_winner\": predicted_winner,\n","        \"predicted_win_probability\": round(predicted_win_probability, 4),\n","        \"predicted_spread_outcome\": predicted_spread_outcome,\n","        \"predicted_spread_confidence\": round(predicted_spread_confidence, 4)\n","    }\n","\n","# --- Apply probability and form adjustments ---\n","\n","for game_key, game_data in nba_game_details_data.items():\n","    for odds_entry in game_data['odds']:\n","        money_line_home = odds_entry['money_line_home']\n","        money_line_away = odds_entry['money_line_away']\n","\n","        # Calculate implied probabilities (raw)\n","        implied_prob_home = convert_american_odds_to_implied_probability(money_line_home)\n","        implied_prob_away = convert_american_odds_to_implied_probability(money_line_away)\n","\n","        # Calculate vig (overround)\n","        vig = (implied_prob_home + implied_prob_away) - 1\n","\n","        # Adjust probabilities to remove vig (normalize to 1)\n","        if (implied_prob_home + implied_prob_away) > 0:\n","            true_prob_home = implied_prob_home / (implied_prob_home + implied_prob_away)\n","            true_prob_away = implied_prob_away / (implied_prob_home + implied_prob_away)\n","        else:\n","            true_prob_home = 0.5 # Default if sum is zero (should not happen with valid odds)\n","            true_prob_away = 0.5\n","\n","        # Store calculated values in the odds_entry\n","        odds_entry['implied_prob_home'] = round(implied_prob_home, 4)\n","        odds_entry['implied_prob_away'] = round(implied_prob_away, 4)\n","        odds_entry['vig'] = round(vig, 4)\n","        odds_entry['true_prob_home'] = round(true_prob_home, 4)\n","        odds_entry['true_prob_away'] = round(true_prob_away, 4)\n","\n","# Apply TeamFormPlugin logic\n","team_form_plugin = TeamFormPlugin()\n","adjustment_percentage = 0.02 # 2% adjustment\n","\n","for game_key, game_data in nba_game_details_data.items():\n","    for odds_entry in game_data['odds']:\n","        home_team = odds_entry['home_team']\n","        away_team = odds_entry['away_team']\n","\n","        home_form_data = team_form_plugin.get_form_data(home_team)\n","        away_form_data = team_form_plugin.get_form_data(away_team)\n","\n","        home_form_score = sum(home_form_data['form'])\n","        away_form_score = sum(away_form_data['form'])\n","\n","        form_adjusted_true_prob_home = odds_entry['true_prob_home']\n","        form_adjusted_true_prob_away = odds_entry['true_prob_away']\n","        form_notes = \"No form adjustment.\"\n","\n","        if odds_entry['true_prob_home'] > odds_entry['true_prob_away']:\n","            favored_team_ml = home_team\n","        else:\n","            favored_team_ml = away_team\n","\n","        if home_form_score > away_form_score:\n","            if favored_team_ml == home_team:\n","                form_adjusted_true_prob_home = round(min(1.0, odds_entry['true_prob_home'] * (1 + adjustment_percentage)), 4)\n","                form_adjusted_true_prob_away = round(max(0.0, odds_entry['true_prob_away'] * (1 - adjustment_percentage)), 4)\n","                form_notes = f\"Confidence in {home_team} increased by {adjustment_percentage*100:.0f}% due to better home team form.\"\n","            else:\n","                form_adjusted_true_prob_home = round(min(1.0, odds_entry['true_prob_home'] * (1 + adjustment_percentage/2)), 4)\n","                form_adjusted_true_prob_away = round(max(0.0, odds_entry['true_prob_away'] * (1 - adjustment_percentage/2)), 4)\n","                form_notes = f\"Slight confidence adjustment for {home_team} (+{adjustment_percentage*50:.0f}%) due to better home team form despite being ML underdog.\"\n","\n","        elif away_form_score > home_form_score:\n","            if favored_team_ml == away_team:\n","                form_adjusted_true_prob_away = round(min(1.0, odds_entry['true_prob_away'] * (1 + adjustment_percentage)), 4)\n","                form_adjusted_true_prob_home = round(max(0.0, odds_entry['true_prob_home'] * (1 - adjustment_percentage)), 4)\n","                form_notes = f\"Confidence in {away_team} increased by {adjustment_percentage*100:.0f}% due to better away team form.\"\n","            else:\n","                form_adjusted_true_prob_away = round(min(1.0, odds_entry['true_prob_away'] * (1 + adjustment_percentage/2)), 4)\n","                form_adjusted_true_prob_home = round(max(0.0, odds_entry['true_prob_home'] * (1 - adjustment_percentage/2)), 4)\n","                form_notes = f\"Slight confidence adjustment for {away_team} (+{adjustment_percentage*50:.0f}%) due to better away team form despite being ML underdog.\"\n","\n","        total_adjusted_prob = form_adjusted_true_prob_home + form_adjusted_true_prob_away\n","        if total_adjusted_prob != 0:\n","            form_adjusted_true_prob_home = round(form_adjusted_true_prob_home / total_adjusted_prob, 4)\n","            form_adjusted_true_prob_away = round(form_adjusted_true_prob_away / total_adjusted_prob, 4)\n","\n","        odds_entry['form_adjusted_true_prob_home'] = form_adjusted_true_prob_home\n","        odds_entry['form_adjusted_true_prob_away'] = form_adjusted_true_prob_away\n","        odds_entry['form_notes'] = form_notes\n","\n","# --- Generate predictions for all NBA games ---\n","\n","all_nba_predictions = {}\n","\n","for game_key, game_data in nba_game_details_data.items():\n","    predictions = predict_nba_game(game_data)\n","    game_data['predictions'] = predictions\n","    all_nba_predictions[game_key] = predictions # Store separately for easy access if needed\n","\n","print(\"Generated predictions for all NBA games.\")\n","\n","# --- Display sorted money line predictions ---\n","\n","money_line_predictions = []\n","\n","for game_key, game_data in nba_game_details_data.items():\n","    if game_data.get('odds') and game_data['odds'][0]:\n","        home_team = game_data['odds'][0]['home_team']\n","        away_team = game_data['odds'][0]['away_team']\n","    else:\n","        home_team = \"N/A\"\n","        away_team = \"N/A\"\n","\n","    predictions = game_data.get('predictions')\n","\n","    if predictions and 'predicted_winner' in predictions and 'predicted_win_probability' in predictions:\n","        money_line_entry = {\n","            \"game_key\": game_key,\n","            \"home_team\": home_team,\n","            \"away_team\": away_team,\n","            \"predicted_winner\": predictions['predicted_winner'],\n","            \"predicted_win_probability\": predictions['predicted_win_probability']\n","        }\n","        money_line_predictions.append(money_line_entry)\n","\n","sorted_money_line_predictions = sorted(money_line_predictions, key=lambda x: x['predicted_win_probability'], reverse=True)\n","\n","\n","print(\"\\n--- Daily NBA Money Line Predictions (03/13/2026) ---\")\n","\n","if not sorted_money_line_predictions:\n","    print(\"No NBA money line predictions available for today.\")\n","else:\n","    for i, entry in enumerate(sorted_money_line_predictions):\n","        if i == 0:\n","            print(\"\\n*** HIGHEST PROBABILITY MONEY LINE BET ***\")\n","        else:\n","            print(\"\\n--