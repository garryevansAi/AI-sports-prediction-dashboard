way Team: Wizards\n","      Favored Team: Magic (-7.0)\n","      Underdog Team: Wizards (+7.0)\n","      Implied Expected Margin: Magic is expected to win by 7.0 points. For the spread, Magic needs to win by more than 7.0 points to cover.\n","      Spread Home: -7.0 (-110), Spread Away: 7.0 (-110)\n","      Implied Spread Outcome: Magic covers with spread -7.0\n","    -----------------------------------\n","\n","Game: Nets @ Hawks\n","  Requested Game: Nets @ Hawks\n","    Source: CBS Sports\n","      Home Team: Hawks | Away Team: Nets\n","      Favored Team: Hawks (-3.5)\n","      Underdog Team: Nets (+3.5)\n","      Implied Expected Margin: Hawks is expected to win by 3.5 points. For the spread, Hawks needs to win by more than 3.5 points to cover.\n","      Spread Home: -3.5 (-110), Spread Away: 3.5 (-110)\n","      Implied Spread Outcome: Hawks covers with spread -3.5\n","    -----------------------------------\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"ab7ebddd","executionInfo":{"status":"ok","timestamp":1773378050376,"user_tz":240,"elapsed":5338,"user":{"displayName":"garry evans","userId":"18049878967172356456"}},"outputId":"51c62e43-761c-49ad-d83c-58b3293a310f"},"source":["import pandas as pd\n","import plotly.express as px\n","\n","# Assuming nba_game_details_data is already loaded and updated from previous steps\n","\n","print(\"--- Visualizing Spread Discrepancies Between Sportsbooks ---\")\n","\n","for game_key, game_data in nba_game_details_data.items():\n","    odds_entries = game_data.get('odds', [])\n","\n","    if not odds_entries or len(odds_entries) < 2: # Need at least 2 sources to show discrepancy\n","        continue\n","\n","    # Prepare data for Plotly\n","    plot_data = []\n","    for entry in odds_entries:\n","        source = entry['source']\n","        home_team = entry['home_team']\n","        away_team = entry['away_team']\n","        spread_home = entry.get('spread_home')\